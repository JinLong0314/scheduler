# Kairo environment example — copy to .env.local (.env.local 不会被提交)
# Cloudflare 账户凭证（由 `kairo init` 自动写入 .env.local）
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare 资源 ID（init 完成后填入 apps/worker/wrangler.toml）
KAIRO_D1_ID=
KAIRO_KV_ID=
KAIRO_R2_BUCKET=kairo-files

# Web 开发时代理的 API Worker（留空则默认使用 Vite 代理 /api → http://127.0.0.1:8787）
VITE_API_URL=
