{
  "expo": {
    "name": "Kairo",
    "slug": "kairo",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "kairo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.kairo.mobile"
    },
    "android": {
      "package": "app.kairo.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#FAF3E8"
      },
      "permissions": ["VIBRATE", "RECEIVE_BOOT_COMPLETED"]
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e9d18757-0397-48e1-9c00-413bd3dcfc63"
      }
    }
  }
}
