{
  "expo": {
    "name": "Kairo",
    "slug": "kairo",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kairo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B6BF0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.kairo.mobile"
    },
    "android": {
      "package": "app.kairo.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B6BF0"
      },
      "permissions": ["VIBRATE", "RECEIVE_BOOT_COMPLETED"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e9d18757-0397-48e1-9c00-413bd3dcfc63"
      }
    }
  }
}
